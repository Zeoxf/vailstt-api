# VailsTT Server — Environment Variables
# Copy this to .env and fill in the values

# Port the server will listen on (Railway/Render sets this automatically)
PORT=3000

# Optional: override yt-dlp binary path (leave blank to use bundled yt-dlp-exec default)
# YTDLP_PATH=/usr/local/bin/yt-dlp

# Optional: set to "production" for cleaner logs
NODE_ENV=development
