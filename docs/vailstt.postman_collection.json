{
  "info": {
    "_postman_id": "vailstt-server-v3",
    "name": "VailsTT Server v3 — Universal Downloader API",
    "description": "Koleksi lengkap endpoint VailsTT Server v3. Set variable `base_url` ke URL server kamu.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string",
      "description": "Ganti dengan URL server kamu, contoh: https://vailstt-server.up.railway.app"
    },
    {
      "key": "youtube_url",
      "value": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
      "type": "string"
    },
    {
      "key": "tiktok_url",
      "value": "https://www.tiktok.com/@khaby.lame/video/7137423965982174469",
      "type": "string"
    },
    {
      "key": "instagram_url",
