  "item": [
    {
      "name": "🟢 Health Check",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/health",
              "host": ["{{base_url}}"],
              "path": ["api", "health"]
            },
            "description": "Cek apakah server online."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"success\": true,\n  \"status\": \"online\",\n  \"uptime\": 12345,\n  \"version\": \"3.0.0\",\n  \"engine\": \"yt-dlp\"\n}"
            }
          ]
        },
        {
          "name": "GET / (Server info)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/",
              "host": ["{{base_url}}"],
              "path": [""]
            }
          }
        }
      ]
    },
    {
